{
  "name": "world-infra-data",
  "version": "1.0.0",
  "description": "TypeScript/JavaScript client for the World Infrastructure Data Hub open API — fuel prices, electricity, EV charging, CO2 and World Bank indicators.",
  "keywords": ["fuel-prices", "electricity", "ev", "co2", "world-bank", "open-data"],
  "license": "MIT",
  "author": "aykutsp",
  "homepage": "https://aykutsp.github.io/world-infrastructure-data-hub/",
  "repository": {
    "type": "git",
    "url": "https://github.com/aykutsp/world-infrastructure-data-hub.git",
    "directory": "libraries/typescript"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node build.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
