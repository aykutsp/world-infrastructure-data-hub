{
  "name": "world-infrastructure-data-hub",
  "private": true,
  "version": "1.1.0",
  "description": "Interactive world map of retail fuel prices, electricity prices, EV charging costs and CO2 emissions, aggregated from open government and inter-governmental data sources.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-data": "node scripts/generateData.js",
    "validate": "node scripts/validateDataset.mjs",
    "build": "npm run generate-data && tsc -b && vite build",
    "build:ci": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "screenshots": "node scripts/takeScreenshots.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.4"
  }
}
