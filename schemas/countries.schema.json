{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aykutsp.github.io/world-infrastructure-data-hub/api/v1/countries.schema.json",
  "title": "World Infrastructure Data Hub — countries.json",
  "description": "Machine-readable contract for the canonical dataset published at /api/v1/countries.json. See ADR-0007 for the stability pledge.",
  "type": "object",
  "required": ["lastUpdated", "sources", "coverage", "countries"],
  "additionalProperties": false,
  "properties": {
    "lastUpdated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp at which the pipeline finished running."
    },
    "sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Human-readable list of upstream sources + licences."
    },
    "coverage": {
      "type": "object",
      "description": "Row count per loader, used for the health dashboard.",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "countries": {
      "type": "array",
      "items": { "$ref": "#/definitions/country" }
    }
  },
  "definitions": {
    "country": {
      "type": "object",
      "required": ["id", "name", "lat", "lng"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2 country code, upper case."
        },
        "iso3": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "name": { "type": "string", "minLength": 1 },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 },

        "fuel": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/fuelBlock" }] },
        "electricity": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/electricityBlock" }] },
        "ev": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/evBlock" }] },
        "co2": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/co2Block" }] },
        "gridCO2": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/gridCO2Block" }] },
        "worldBank": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/worldBankBlock" }] },
        "chargingStations": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/chargingBlock" }] },
        "happiness": { "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/happinessBlock" }] }
      }
    },

    "fuelBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gasoline": { "type": ["number", "null"] },
        "diesel": { "type": ["number", "null"] },
        "lpg": { "type": ["number", "null"] },
        "source": { "type": "string" }
      }
    },

    "electricityBlock": {
      "type": "object",
      "required": ["household_usd_per_kwh", "year"],
      "additionalProperties": false,
      "properties": {
        "household_usd_per_kwh": { "type": "number", "minimum": 0 },
        "year": { "type": "integer", "minimum": 1950, "maximum": 2100 },
        "period": { "type": "string" },
        "source": { "type": "string" }
      }
    },

    "evBlock": {
      "type": "object",
      "required": ["home_usd_per_100km", "public_fast_usd_per_100km", "assumptions"],
      "additionalProperties": false,
      "properties": {
        "home_usd_per_100km": { "type": "number", "minimum": 0 },
        "public_fast_usd_per_100km": { "type": "number", "minimum": 0 },
        "assumptions": {
          "type": "object",
          "required": ["consumption_kwh_per_100km", "fast_charger_markup"],
          "additionalProperties": false,
          "properties": {
            "consumption_kwh_per_100km": { "type": "number", "exclusiveMinimum": 0 },
            "fast_charger_markup": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      }
    },

    "co2Block": {
      "type": "object",
      "required": ["year", "tonnes_per_capita"],
      "additionalProperties": false,
      "properties": {
        "year": { "type": "integer", "minimum": 1800, "maximum": 2100 },
        "tonnes_per_capita": { "type": "number", "minimum": 0 },
        "total_million_tonnes": { "type": ["number", "null"] },
        "history": { "$ref": "#/definitions/numberSeries" },
        "source": { "type": "string" }
      }
    },

    "gridCO2Block": {
      "type": "object",
      "required": ["gco2_per_kwh", "year"],
      "additionalProperties": false,
      "properties": {
        "gco2_per_kwh": { "type": "number", "minimum": 0, "maximum": 2000 },
        "year": { "type": "integer", "minimum": 1980, "maximum": 2100 },
        "source": { "type": "string" }
      }
    },

    "worldBankBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gdp_per_capita_usd": { "$ref": "#/definitions/wbIndicator" },
        "population": { "$ref": "#/definitions/wbIndicator" },
        "life_expectancy_years": { "$ref": "#/definitions/wbIndicator" },
        "internet_users_pct": { "$ref": "#/definitions/wbIndicator" },
        "renewable_electricity_pct": { "$ref": "#/definitions/wbIndicator" },
        "gini_index": { "$ref": "#/definitions/wbIndicator" },
        "unemployment_pct": { "$ref": "#/definitions/wbIndicator" },
        "inflation_pct": { "$ref": "#/definitions/wbIndicator" }
      }
    },

    "wbIndicator": {
      "type": "object",
      "required": ["value", "year"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number" },
        "year": { "type": "integer", "minimum": 1950, "maximum": 2100 },
        "source": { "type": "string" },
        "history": { "$ref": "#/definitions/numberSeries" }
      }
    },

    "chargingBlock": {
      "type": "object",
      "required": ["operational_stations"],
      "additionalProperties": false,
      "properties": {
        "operational_stations": { "type": "integer", "minimum": 0 },
        "source": { "type": "string" }
      }
    },

    "happinessBlock": {
      "type": "object",
      "required": ["score", "year"],
      "additionalProperties": false,
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 10 },
        "year": { "type": "integer", "minimum": 2000, "maximum": 2100 },
        "source": { "type": "string" }
      }
    },

    "numberSeries": {
      "type": "array",
      "items": {
        "type": "array",
        "items": [
          { "type": "integer", "minimum": 1800, "maximum": 2100 },
          { "type": "number" }
        ],
        "minItems": 2,
        "maxItems": 2
      }
    }
  }
}
